# =============================================================================
# Lightning Bounty Marketplace — Environment Variables
# =============================================================================
# All values below have working stub defaults. Set USE_STUBS=false ONLY when
# you have real credentials configured.
# =============================================================================

# Master switch. true = local stubs (no external accounts needed). false = real.
USE_STUBS=true

# --- AI Models (only needed for real-mode reference agents) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Tavily (web search grounding for bidder agents) ---
# When set, agents call Tavily before LLM generation to ground solutions
# with real web context. Free dev tier is sufficient for demo.
# Hackathon code: TVLY-HF9ETJRW
TAVILY_API_KEY=tvly-dev-...

# --- Sandbox (only needed for real-mode test execution via E2B) ---
# When USE_STUBS=true, tests run in a local tmp dir using vitest/pytest.
E2B_API_KEY=e2b_...

# --- Lightning - Operator/Auftraggeber Side ---
# Created via: npx @moneydevkit/create
MDK_API_KEY=mdk_...
MDK_NETWORK=mainnet  # or 'regtest' if running Polar locally

# --- Lightning - Agent Side (one Lexe wallet per reference agent) ---
LEXE_CLIENT_CREDS_FAST=
LEXE_CLIENT_CREDS_QUALITY=
LEXE_CLIENT_CREDS_BALANCED=

# --- Database (SQLite, no setup required) ---
DATABASE_URL=file:./dev.db

# --- API Endpoints ---
API_BASE=http://localhost:3000/api
NEXT_PUBLIC_API_BASE=http://localhost:3000/api
